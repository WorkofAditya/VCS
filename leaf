#!/usr/bin/env python3
import os, sys, json, time, hashlib, difflib, shutil

VCS_DIR = ".leaf"
COMMITS_DIR = os.path.join(VCS_DIR, "commits")
LOG_FILE = os.path.join(VCS_DIR, "log.json")
LOG_BACKUP = os.path.join(VCS_DIR, "log.bak")

LEAF = "🍃"
SPROUT = "🌱"
HERB = "🌿"
DRY = "🍂"
TREE = "🌳"

def leaf_init():
    os.makedirs(COMMITS_DIR, exist_ok=True)
    if not os.path.exists(LOG_FILE):
        with open(LOG_FILE, "w") as f:
            json.dump([], f)
    print(f"{SPROUT} Initialized empty leaf repository")

def leaf_hash_commit(data):
    return hashlib.sha1(data.encode()).hexdigest()

def is_binary(path):
    try:
        with open(path, "rb") as f:
            chunk = f.read(1024)
            if b"\0" in chunk:
                return True
    except:
        return True
    return False

def leaf_read_file(path):
    try:
        with open(path, "r", errors="ignore") as f:
            return f.readlines()
    except:
        return []

def leaf_write_file(path, lines):
    dirpath = os.path.dirname(path)
    if dirpath:
        os.makedirs(dirpath, exist_ok=True)
    with open(path, "w") as f:
        f.writelines(lines)

def leaf_get_all_files():
    files = []
    for root, dirs, fs in os.walk("."):
        if VCS_DIR in root:
            continue
        for f in fs:
            files.append(os.path.relpath(os.path.join(root, f), "."))
    return files

def leaf_snapshot(commit_path):
    for file in leaf_get_all_files():
        dest = os.path.join(commit_path, file)
        os.makedirs(os.path.dirname(dest), exist_ok=True)
        shutil.copy2(file, dest)

def safe_load_log():
    try:
        with open(LOG_FILE, "r") as f:
            return json.load(f)
    except:
        if os.path.exists(LOG_BACKUP):
            with open(LOG_BACKUP, "r") as f:
                return json.load(f)
        return []

def safe_save_log(log):
    if os.path.exists(LOG_FILE):
        shutil.copy2(LOG_FILE, LOG_BACKUP)
    with open(LOG_FILE, "w") as f:
        json.dump(log, f, indent=2)

def leaf_save(msg):
    if not os.path.exists(VCS_DIR):
        print(f"{DRY} Not a repository")
        return

    log = safe_load_log()

    timestamp = time.strftime("%Y-%m-%d %H:%M:%S")
    commit_id = leaf_hash_commit(msg + timestamp + str(time.time()))[:10]
    commit_path = os.path.join(COMMITS_DIR, commit_id)

    commit_data = {
        "id": commit_id,
        "message": msg,
        "time": timestamp,
        "type": "diff",
        "changes": {},
        "deleted": []
    }

    current_files = set(leaf_get_all_files())

    if not log:
        os.makedirs(commit_path)
        leaf_snapshot(commit_path)
        commit_data["type"] = "snapshot"
        commit_data["files"] = list(current_files)
    else:
        prev_commit = log[-1]["id"]
        prev_path = os.path.join(COMMITS_DIR, prev_commit)

        prev_files = set()
        for root, _, fs in os.walk(prev_path):
            for f in fs:
                rel = os.path.relpath(os.path.join(root, f), prev_path)
                if not rel.endswith(".diff"):
                    prev_files.add(rel)

        deleted = prev_files - current_files
        commit_data["deleted"] = list(deleted)

        for file in current_files:
            if is_binary(file):
                continue
            new = leaf_read_file(file)
            old = leaf_read_file(os.path.join(prev_path, file))
            if new != old:
                diff = list(difflib.ndiff(old, new))
                commit_data["changes"][file] = diff

        if not commit_data["changes"] and not deleted:
            print(f"{DRY} No changes detected, nothing to save")
            return

        os.makedirs(commit_path)

        for file, diff in commit_data["changes"].items():
            save_path = os.path.join(commit_path, file + ".diff")
            os.makedirs(os.path.dirname(save_path), exist_ok=True)
            with open(save_path, "w") as f:
                f.write("\n".join(diff))

    log.append(commit_data)
    safe_save_log(log)

    print(f"{LEAF} Saved commit {commit_id}")

def leaf_rebuild(commit_id, log):
    files = {}

    for c in log:
        cid = c["id"]
        cpath = os.path.join(COMMITS_DIR, cid)

        if c["type"] == "snapshot":
            for root, _, fs in os.walk(cpath):
                for f in fs:
                    rel = os.path.relpath(os.path.join(root, f), cpath)
                    files[rel] = leaf_read_file(os.path.join(root, f))
        else:
            for file in c.get("deleted", []):
                if file in files:
                    del files[file]

            for file, diff in c["changes"].items():
                old = files.get(file, [])
                patched = []
                for line in diff:
                    if line.startswith("  ") or line.startswith("+ "):
                        patched.append(line[2:])
                files[file] = patched

        if cid == commit_id:
            return files

    return None

def leaf_restore(commit_id):
    if not os.path.exists(LOG_FILE):
        print(f"{DRY} No commits")
        return

    log = safe_load_log()
    ids = [c["id"] for c in log]

    if commit_id not in ids:
        print(f"{DRY} Invalid commit id")
        return

    files = leaf_rebuild(commit_id, log)
    if files is None:
        print(f"{DRY} Restore failed")
        return

    temp_dir = ".leaf_restore_tmp"
    if os.path.exists(temp_dir):
        shutil.rmtree(temp_dir)
    os.makedirs(temp_dir)

    for path, content in files.items():
        full = os.path.join(temp_dir, path)
        os.makedirs(os.path.dirname(full), exist_ok=True)
        with open(full, "w") as f:
            f.writelines(content)

    current_files = set(leaf_get_all_files())
    target_files = set(files.keys())

    for f in current_files - target_files:
        try:
            os.remove(f)
        except:
            pass

    for path in target_files:
        src = os.path.join(temp_dir, path)
        dst = path
        os.makedirs(os.path.dirname(dst) or ".", exist_ok=True)
        shutil.copy2(src, dst)

    shutil.rmtree(temp_dir)

    print(f"{TREE} Restored to commit {commit_id}")

def leaf_log():
    if not os.path.exists(LOG_FILE):
        print(f"{DRY} No commits")
        return

    log = safe_load_log()

    for c in reversed(log):
        print(f"\n{HERB} Commit: {c['id']}")
        print(f"{LEAF} Message: {c['message']}")
        print(f"{SPROUT} Time: {c['time']}")

def main():
    if len(sys.argv) < 2:
        return

    cmd = sys.argv[1]

    if cmd == "init":
        leaf_init()
    elif cmd == "save":
        msg = " ".join(sys.argv[2:])
        leaf_save(msg)
    elif cmd == "log":
        leaf_log()
    elif cmd == "restore":
        if len(sys.argv) < 3:
            print(f"{DRY} Missing commit id")
            return
        leaf_restore(sys.argv[2])

if __name__ == "__main__":
    main()
